<mujoco>
    <compiler meshdir="../meshes/Gripper" />

    <include file="materials.xml" />

    <default>
        <default class="visual">
            <geom pos="0.0 0.0 0.0" euler="0 0 0" />
            <!-- <geom pos="0.3 0.0 0.2" euler="0 0 0" /> -->
        </default>
    </default>

    

    <asset>
        <mesh name="Gripper1" file="Gripper1.stl" scale="2.0 2.0 2.0" />
        <mesh name="Gripper2" file="Gripper2.stl" scale="2.0 2.0 2.0" />
    </asset>

    <worldbody>
        <body name="Gripper1" pos="0.0 0.0 0.0" euler="90 0 30">
             <!-- <geom type="mesh" mesh="Gripper1" class="visual" material="brown" mass="0.2" contype="1" conaffinity="1"  /> -->
            <geom type="mesh" mesh="Gripper1" class="visual" material="silver" mass="0.1" contype="1" conaffinity="1"  />
        </body>
        <body name="Gripper2" pos="0 0 0.0" euler="90 180 30">
            <geom type="mesh" mesh="Gripper2" class="visual" material="brown" mass="0.1" contype="1" conaffinity="1"  />
        </body>
    </worldbody>
</mujoco>